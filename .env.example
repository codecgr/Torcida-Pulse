TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
SOLANA_SIMULATION_PAYER=
# Public HTTPS origin used by permanent NFT metadata (required for deployment).
PUBLIC_APP_ORIGIN=
# Production: 64-byte JSON secret array stored only in the host secret manager.
SOLANA_COLLECTIBLE_AUTHORITY=
# Local development only; defaults to the ignored 0600 file below.
SOLANA_COLLECTIBLE_AUTHORITY_PATH=secrets/collectible-authority.json
# Required for production real-data access. Share only in private judge notes.
JUDGE_ACCESS_TOKEN=
# Required in production. Use the authorized cutoff confirmed by TxODDS (ISO-8601 UTC).
REAL_DATA_DISABLE_AT=
REPLAY_CACHE_TTL_MS=300000
REPLAY_RATE_LIMIT_MAX=30
REPLAY_RATE_LIMIT_WINDOW_MS=60000
